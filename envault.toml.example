# envault.toml — example configuration
# Copy to envault.toml and adjust for your project.

[sync]
# Default AWS region (can be overridden per profile)
region = "us-east-1"

# Default SSM path prefix for single-profile workflows
path_prefix = "/myapp/dev"

# Output .env file written by `envault sync`
output = ".env"

# Recursively fetch all parameters under path_prefix (default: true)
recursive = true

# Audit log location (default: .envault_audit.jsonl)
audit_log = ".envault_audit.jsonl"

# Cache TTL in seconds (default: 300 = 5 min, 0 = disabled)
cache_ttl = 300


# ---------------------------------------------------------------------------
# Named profiles — use with: envault sync --profile <name>
# Each profile can target a different SSM path and output file.
# ---------------------------------------------------------------------------

[profiles.dev]
path_prefix = "/myapp/dev"
output     = ".env.dev"
region     = "us-east-1"
recursive  = true

[profiles.staging]
path_prefix = "/myapp/staging"
output     = ".env.staging"
region     = "us-east-1"

[profiles.prod]
path_prefix = "/myapp/prod"
output     = ".env.prod"
region     = "us-east-1"
recursive  = false
# Extra metadata tags stored in audit entries for this profile
[profiles.prod.extra_tags]
environment = "production"
team        = "platform"
